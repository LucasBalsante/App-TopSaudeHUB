BACKEND_CONNECTION_STRING=Host=localhost;Port=5432;Database=your_database_name;Username=your_postgres_user;Password=your_postgres_password
BACKEND_CONNECTION_STRING_CONTAINER=Host=db;Port=5432;Database=your_database_name;Username=your_postgres_user;Password=your_postgres_password

FRONTEND_PORT=4200
